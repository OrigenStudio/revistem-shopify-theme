{% doc %}
  @prompt
    I want to design a “brand positioning / statement” section for a premium hair supplement brand (Revistem).
    
    Context:
    - Brand tone: clinical, honest, minimal, evidence-based
    - Not marketing-driven, no exaggerated claims
    - Aesthetic: clean, elegant, similar to Aesop / The Ordinary
    - This section should feel like a strong brand statement, not a sales block
    
    Main message (keep this exact idea, you can refine slightly):
    "No vendemos resultados milagrosos. Vendemos constancia con criterio."
    
    Goal:
    Create a visually impactful but minimal section that communicates this philosophy clearly.
    
    Requirements:
    - Very minimal layout, lots of white space
    - Centered content
    - One main statement (large typography)
    - Optional short supporting line below (1 sentence max)
    - No buttons, no distractions
    - Should feel editorial, almost like a quote
    
    Design direction:
    - Large serif or elegant font for the main statement
    - Subtle contrast (light background or soft neutral tone)
    - No boxes, no heavy UI elements
    - Could include very subtle divider or spacing above/below
    
    Also:
    - Suggest a refined version of the main sentence in Spanish (keep same meaning)
    - Provide 2–3 variations of supporting microcopy (short, premium tone)
    
    Output:
    - Final Spanish copy (main statement + optional supporting line)
    - Layout description (spacing, alignment, hierarchy)
    - Typography suggestion (style, weight, scale)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-statement-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.spacing_top }}px 20px {{ block.settings.spacing_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-brand-statement__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-brand-statement__divider-top-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: 0 auto {{ block.settings.divider_spacing }}px;
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
  }

  .ai-brand-statement__main-{{ ai_gen_id }} {
    font-family: {{ block.settings.main_font.family }}, {{ block.settings.main_font.fallback_families }};
    font-weight: {{ block.settings.main_font.weight }};
    font-style: {{ block.settings.main_font.style }};
    font-size: {{ block.settings.main_font_size }}px;
    line-height: {{ block.settings.main_line_height }};
    color: {{ block.settings.main_text_color }};
    margin: 0;
    letter-spacing: {{ block.settings.main_letter_spacing }}px;
  }

  .ai-brand-statement__supporting-{{ ai_gen_id }} {
    font-family: {{ block.settings.supporting_font.family }}, {{ block.settings.supporting_font.fallback_families }};
    font-weight: {{ block.settings.supporting_font.weight }};
    font-style: {{ block.settings.supporting_font.style }};
    font-size: {{ block.settings.supporting_font_size }}px;
    line-height: {{ block.settings.supporting_line_height }};
    color: {{ block.settings.supporting_text_color }};
    margin: {{ block.settings.supporting_spacing }}px 0 0;
    letter-spacing: {{ block.settings.supporting_letter_spacing }}px;
    opacity: {{ block.settings.supporting_opacity | divided_by: 100.0 }};
  }

  .ai-brand-statement__divider-bottom-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_spacing }}px auto 0;
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
  }

  @media screen and (max-width: 749px) {
    .ai-brand-statement-{{ ai_gen_id }} {
      padding: {{ block.settings.spacing_top_mobile }}px 16px {{ block.settings.spacing_bottom_mobile }}px;
    }

    .ai-brand-statement__main-{{ ai_gen_id }} {
      font-size: {{ block.settings.main_font_size_mobile }}px;
    }

    .ai-brand-statement__supporting-{{ ai_gen_id }} {
      font-size: {{ block.settings.supporting_font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-brand-statement-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-statement__container-{{ ai_gen_id }}">
    {% if block.settings.show_divider_top %}
      <div class="ai-brand-statement__divider-top-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.main_text != blank %}
      <h2 class="ai-brand-statement__main-{{ ai_gen_id }}">
        {{ block.settings.main_text }}
      </h2>
    {% endif %}

    {% if block.settings.supporting_text != blank %}
      <p class="ai-brand-statement__supporting-{{ ai_gen_id }}">
        {{ block.settings.supporting_text }}
      </p>
    {% endif %}

    {% if block.settings.show_divider_bottom %}
      <div class="ai-brand-statement__divider-bottom-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</div>

