{% doc %}
  @prompt
    I want to redesign a “trust badges / value propositions” section for a premium hair supplement brand (Revistem).
    
    Context:
    - Brand positioning: premium, clinical, pharmacy-grade
    - Aesthetic: minimal, clean, elegant (inspired by Aesop / The Ordinary / Belevels)
    - Current messages: 
      • Fabricado en España  
      • Envío 24–48h  
      • Envío gratis a partir de 69€  
      • Ingredientes premium  
      • Sin ingredientes de relleno  
      • Fórmula confiable  
    
    Goal:
    Create a refined, high-end version of this section that feels consistent with a premium pharmaceutical brand.
    
    Requirements:
    - Layout: horizontal row (desktop), stacked (mobile)
    - Use subtle, minimal icons (thin line icons, monochrome, no emojis)
    - Typography: elegant, lots of whitespace, not crowded
    - Each item should have:
      → short title (max 3–4 words)
      → optional microcopy (1 short supporting line)
    - Avoid looking like a generic Shopify “trust badges” block
    - Keep it understated, not loud or salesy
    
    Design direction:
    - Inspired by Aesop / The Ordinary product pages
    - Soft spacing, refined alignment
    - Icons should feel “medical / clinical / premium”, not e-commerce cliché
    - Consider using separators or subtle dividers instead of boxes
    
    Also:
    - Suggest improved copy in Spanish (short, premium tone)
    - Suggest icon style (e.g., outline icons, stroke width, references)
    - Keep everything very minimal and premium
    
    Output:
    - Final copy (Spanish)
    - Layout description
    - Icon suggestions (per item)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    display: block;
  }

  .ai-trust-badges__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: stretch;
    gap: {{ block.settings.item_spacing }}px;
    padding: {{ block.settings.section_padding_vertical }}px {{ block.settings.section_padding_horizontal }}px;
  }

  .ai-trust-badges__item-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    gap: {{ block.settings.icon_text_spacing }}px;
    position: relative;
  }

  .ai-trust-badges__item-{{ ai_gen_id }}:not(:last-child)::after {
    content: '';
    position: absolute;
    right: calc(-{{ block.settings.item_spacing }}px / 2);
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: {{ block.settings.divider_height }}%;
    background-color: {{ block.settings.divider_color }};
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
    display: {% if block.settings.show_dividers %}block{% else %}none{% endif %};
  }

  .ai-trust-badges__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-trust-badges__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: {{ block.settings.icon_stroke_width }};
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-trust-badges__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.title_description_spacing }}px;
  }

  .ai-trust-badges__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    line-height: 1.3;
    margin: 0;
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-trust-badges__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    letter-spacing: {{ block.settings.description_letter_spacing }}px;
    line-height: 1.5;
    margin: 0;
    opacity: {{ block.settings.description_opacity | divided_by: 100.0 }};
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badges__container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_item_spacing }}px;
      padding: {{ block.settings.mobile_padding_vertical }}px {{ block.settings.mobile_padding_horizontal }}px;
    }

    .ai-trust-badges__item-{{ ai_gen_id }}:not(:last-child)::after {
      display: none;
    }

    .ai-trust-badges__icon-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_icon_size }}px;
      height: {{ block.settings.mobile_icon_size }}px;
    }

    .ai-trust-badges__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_title_size }}px;
    }

    .ai-trust-badges__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_description_size }}px;
    }
  }
{% endstyle %}

