    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 40,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 40,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
