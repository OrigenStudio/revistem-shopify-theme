<script>
  document.addEventListener('DOMContentLoaded', function () {
    var scrollToTopButton = document.getElementById('scroll-to-top-button-{{ section.id }}');

    if (!scrollToTopButton) return;

    scrollToTopButton.addEventListener('click', function () {
      window.scrollTo({
        top: 0,
        behavior: 'smooth',
      });
    });

    const scrollThreshold = 1 - {{ section.settings.show_when_precent_of_page }} / 100;
    let ticking = false;
    let isVisible = false;

    function updateScrollToTopButton() {
      const shouldShow =
        window.scrollY > scrollThreshold * (document.body.scrollHeight - window.innerHeight);

      if (shouldShow !== isVisible) {
        if (shouldShow) {
          scrollToTopButton.style.display = 'block';
          scrollToTopButton.style.opacity = '1';
        } else {
          scrollToTopButton.style.opacity = '0';
          scrollToTopButton.style.display = 'none';
        }
        isVisible = shouldShow;
      }

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updateScrollToTopButton);
        ticking = true;
      }
    }

    if (scrollThreshold === 1) {
      scrollToTopButton.style.display = 'block';
      scrollToTopButton.style.opacity = '1';
      isVisible = true;
    } else {
      window.addEventListener('scroll', onScroll, { passive: true });
      updateScrollToTopButton();
    }
  });
</script>
